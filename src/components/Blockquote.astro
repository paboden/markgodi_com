---
import Container from "../layouts/Container.astro";

const { citation, ...attr } = Astro.props;
---

<Container bg="yellow" class:list={[attr.class]}>
  <blockquote class="blockquote">
    <slot />
    {citation && <cite class="citation">{citation}</cite>}
  </blockquote>
</Container>

<style>
  .blockquote {
    font-family: "EB Garamond", serif;
    font-size: clamp(1.5rem, 6vw, 2.5rem);
    font-style: italic;
    line-height: 1.3;
    margin: 2rem auto;
    padding: 0;
    text-align: center;
  }

  @media (min-width: 90ch) {
    .blockquote {
      text-align: center;
    }
  }

  .left-align {
    text-align: left;
  }

  .center-align {
    text-align: center;
  }

  .right-align {
    text-align: right;
  }

  cite.citation {
    display: block;
    margin-top: 1rem;
    font-size: 1.25rem;
  }
</style>
