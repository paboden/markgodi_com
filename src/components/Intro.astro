  .profile-pic-wrapper {
    border-radius: 9000px;
    padding: 0.75rem;
    display: inline-flex;
  }

  .profile-pic {
    width: 13rem;
    height: 13rem;
    border-radius: 9000px;
    object-fit: cover;
  }

  @media (min-width: 80ch) {
    .profile-pic {
      /* width: 20rem;
      height: 20rem; */
      width: clamp(13rem, 20vw, 21rem);
