<style>
  h2 {
    text-align: center;
    color: #244057;
  }

  p {
    max-width: 70ch;
    margin: 0 auto;
    text-align: center;
  }

  .social-links {
    display: flex;
    gap: 2rem;
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
    padding: 0;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }

  @media (min-width: 120ch) {
    .social-links {
      flex-direction: row;
      justify-content: center;
    }
  }

  .social-links li {
    /* display: inline-block; */
  }

  .social-links a {
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: normal;
    letter-spacing: 0.02rem;
    font-size: 1rem;
    transition: color 0.2s;
    display: flex;
    gap: 1rem;
    text-align: center;
    font-weight: 500;
    transition: all 0.3s;
    margin-inline: auto;
    background-color: #ebc975;
    color: #244057;
    justify-content: center;
    max-width: 25rem;
  }

  @media (min-width: 120ch) {
    .social-links a {
      /* padding: 1rem 2rem; */
      /* min-width: 15rem; */
      justify-content: center;
      text-align: center;
      flex-direction: row;
      flex-wrap: wrap;
      max-width: unset;
    }
  }

  .social-links a:hover {
    /* background-color: #e3ba3f; */
    background-color: #244057;
    color: white;
    transition: all 0.3s;
  }

  .social-links svg {
    width: 1.5rem;
    height: 1.5rem;
    fill: currentColor;
    color: currentColor;
  }
</style>
