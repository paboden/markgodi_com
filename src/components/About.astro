---
import Container from "../layouts/Container.astro";
import DecorImage from "./DecorImage.astro";
import { Image } from "astro:assets";

import prestonLookingCutout from "../assets/images/preston-looking-cutout.png";
import wascConferencePhoto from "../assets/images/wasc-conference-photo.webp";
---

<Container bg="tan" id="about" spacing="extra">
  <DecorImage src={prestonLookingCutout} width={225} height={201} />

  <h2 id="about">About me</h2>

  <div class="text-columns">
    <p>
      For the last twenty years I’ve worked in public schools as a teacher,
      administrator, and turnaround specialist. I’ve taken campuses from
      “possible probation” to celebrated WASC models, led credential
      certification for future teachers through University of the Pacific, and
      keynoted statewide conferences on the evolving landscape of college and
      career readiness.
    </p>

    <p>
      As a teacher, I built a thriving art program from the ground up, helping
      students find confidence, their voice, and their creative agency. I have
      mentored hundreds of teens navigating the tangled path toward adulthood.
    </p>
  </div>

  <div class="columns">
    <div class="column">
      <h3 id="label-credentials">Credentials</h3>
      <ul aria-labelledby="label-credentials">
        <li>San Joaquin Delta College</li>
        <li>University of the Pacific</li>
        <li>Master’s in Digital Journalism — National University</li>
        <li>Temporary Professor → San Joaquin Delta College</li>
      </ul>
    </div>
    <div class="column">
      <h3 id="label-experience">Experience</h3>
      <ul aria-labelledby="label-experience">
        <li>20+ years in public education</li>
        <li>WASC Coordinator and School-Site Visiting Commitee</li>
        <li>
          Keynote speaker at 2025 NorCal WASC Conference and statewide events
        </li>
      </ul>
    </div>
  </div>

  <figure class="conference-pic">
    <Image
      src={wascConferencePhoto}
      alt="WASC 2025 conference panel seated on stage"
      width={1214}
      height={457}
      widths={[240, 540, 720, 1214]}
      sizes={`(max-width: 360px) 100%, (max-width: 540px) 360px, (max-width: 720px) 540px, (max-width: 1200px) 720px, 1214px`}
      layout="constrained"
      format="webp"
    />
    <figcaption>
      At the 2025 NorCal WASC Conference, where I was a keynote speaker.
    </figcaption>
  </figure>
</Container>

<style>
  .columns {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .text-columns {
    column-count: 1;
    column-gap: 3rem;
  }

  @media (min-width: 120ch) {
    .columns {
      flex-direction: row;
      gap: 3rem;
      margin-block-end: 3rem;
      align-items: center;
    }

    .text-columns {
      column-count: 2;
      margin-block-end: 3rem;
    }
  }

  .columns > .column {
    flex: 1;
  }

  h2 {
    margin-block: 0 3rem;
  }

  @media (min-width: 120ch) {
    h2 {
      text-align: center;
    }
  }

  ul {
    margin-block: 0;
  }

  p {
    margin-block-start: 0;
  }

  figure {
    max-width: 100%;
    margin: 3rem 0 0;
    object-fit: cover;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 120ch) {
    figure {
      margin: 6rem 3rem 0;
    }
  }

  figure img {
    width: 100%;
    border-radius: 1rem;
    object-fit: cover;
  }

  figcaption {
    font-family: var(--font-garamond);
    /* font-family: "EB Garamond", serif; */
    font-size: 0.875rem;
    color: #244057;
    display: block;
    margin-block: 1rem;
    text-align: center;
  }
</style>
